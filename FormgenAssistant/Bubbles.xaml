<Window x:Name="BubblesWindow" x:Class="FormgenAssistant.Bubbles"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FormgenAssistant"
        mc:Ignorable="d"
        Title="Bubbles" Width="50" WindowStyle="None" Background="{x:Null}" Foreground="{x:Null}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Topmost="True" ResizeMode="NoResize" SizeToContent="WidthAndHeight" AllowsTransparency="True" WindowStartupLocation="Manual" ShowInTaskbar="False" MaxHeight="450" SizeChanged="BubblesWindow_SizeChanged">
    <Grid >
        <StackPanel x:Name="stkContent" Orientation="Horizontal">
            <StackPanel  MaxHeight="450" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" CanVerticallyScroll="True" >
                <Grid x:Name="grdGrabber" Cursor="SizeAll" PreviewMouseLeftButtonDown="grdGrabber_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="grdGrabber_PreviewMouseLeftButtonUp" Background="#02FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" Height="20" >
                    <Image Source="/Resources/Grabber.png" Stretch="Uniform" Margin="2,0,2,0" IsHitTestVisible="False"/>
                </Grid>
                <Button x:Name="btnLinks" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="{x:Null}" Click="btnLinks_Click" >
                    <Image Height="45" Source="/Resources/Hyperlink.png" Stretch="Fill" Width="46"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
