<UserControl x:Class="FormgenAssistant.Pages.MultiNotes"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FormgenAssistant.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <TabControl TabStripPlacement="Top" HorizontalAlignment="Stretch" Background="{x:Null}" VerticalAlignment="Stretch" BorderBrush="{x:Null}" FontSize="12" >
            <TabItem Header="Item 1">
                <local:Notes/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
